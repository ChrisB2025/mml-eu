---
interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description = "We make Modern Monetary Theory accessible for everyone.", currentPage = "" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta content="width=device-width, initial-scale=1" name="viewport">

  <!-- CSS -->
  <link href="/styles/normalize.css" rel="stylesheet" type="text/css">
  <link href="/styles/webflow.css" rel="stylesheet" type="text/css">
  <link href="/styles/main.css" rel="stylesheet" type="text/css">
  <link href="/styles/components.css" rel="stylesheet" type="text/css">
  <link href="/styles/responsive-fixes.css" rel="stylesheet" type="text/css">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans&family=Outfit&display=swap" rel="stylesheet">

  <!-- Favicon -->
  <link href="/images/favicon.ico" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">
</head>
<body>
  <slot />

  <!-- Scripts -->
  <script is:inline src="/scripts/nav.js"></script>
  <script is:inline src="/scripts/tabs.js"></script>
  <script is:inline src="/scripts/form-handler.js"></script>
</body>
</html>
