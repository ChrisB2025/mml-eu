---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us - Modern Money Lab Europe" description="Discover the mission, activities, and founding team of Modern Money Lab Europe as we promote understanding of Modern Monetary Theory across Europe.">
  <Nav currentPage="about" />

  <header class="section is-inverse">
    <div class="container is-small">
      <div class="header is-align-center">
        <h1 class="heading_hero">Understanding money, shaping policy</h1>
        <div class="subheading rich-text">
          <p>We make modern monetary theory accessible for everyone. Learn how economies work, why public spending matters, and what drives effective policy in Europe.</p>
        </div>
        <div class="button-group">
          <div class="ix-link-wrapper">
            <a href="#mission" class="button on-inverse btn">Our mission</a>
          </div>
          <div class="ix-link-wrapper">
            <a href="#team" class="button is-secondary on-inverse btn">Meet the team</a>
          </div>
        </div>
      </div>
    </div>
    <div class="content-block">
      <div class="flex_horizontal is-x-center overflow_hidden gap-xsmall">
        <div class="grid-item-manual width_50percent flex-child_no-shrink">
          <div class="image-ratio_3x2">
            <img width="1216" height="832" alt="People networking" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/c4f41780-2208-4c64-8e08-5867f8158c44.avif" loading="lazy" class="image_cover">
          </div>
        </div>
        <div class="grid-item-manual width_50percent flex-child_no-shrink">
          <div class="image-ratio_1x1">
            <img width="1216" height="832" alt="Conference" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/df55c204-aa6d-4464-beef-8e100deb8482.avif" loading="lazy" class="image_cover">
          </div>
        </div>
        <div class="grid-item-manual width_50percent flex-child_no-shrink">
          <div class="image-ratio_3x2">
            <img width="1216" height="832" alt="Educational brochures" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/67ea2c35-1f7a-4f0b-8cf3-d1e4286498df.avif" loading="lazy" class="image_cover">
          </div>
        </div>
      </div>
    </div>
  </header>

  <section id="mission" class="section">
    <div class="container">
      <div class="grid grid_2-col tablet-1-col gap-large">
        <div class="header">
          <div class="tag_group gap-xsmall">
            <div class="eyebrow margin-bottom_none">Our story and mission</div>
            <div class="tag"><div>About us</div></div>
          </div>
          <h2 class="heading_primary">Shaping economic understanding together</h2>
          <div class="tag_group">
            <div class="paragraph_small margin-bottom_none">Taylor Morgan</div>
            <div class="paragraph_small margin-bottom_none">-</div>
            <div class="paragraph_small margin-bottom_none">Co-founder</div>
            <div class="paragraph_small margin-bottom_none">-</div>
            <div class="paragraph_small margin-bottom_none">June 2026</div>
          </div>
        </div>
        <div class="image-ratio_auto">
          <img width="1216" height="832" alt="Team discussion" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/638b0e0b-607f-4d18-a5ca-b69e4f346744.avif" loading="lazy" class="image">
        </div>
      </div>
    </div>
  </section>

  <section id="team" class="section is-secondary">
    <div class="container">
      <div class="grid grid_3-col gap-medium is-y-top tablet-1-col-1-2">
        <div class="header margin-bottom_none">
          <div class="eyebrow">Meet our founding team</div>
          <h2 class="heading_primary">People behind the mission</h2>
          <div class="rich-text subheading">
            <p>Our diverse team brings expertise in economics, policy, and communications to advance monetary understanding across Europe.</p>
          </div>
          <div class="button-group">
            <div class="ix-link-wrapper">
              <a href="mailto:info@modernmoneylab.eu" class="button btn">Contact us</a>
            </div>
          </div>
        </div>
        <div class="grid-item-manual">
          <div class="grid grid_2-col gap-small">
            <div class="ix-link-wrapper">
              <a href="#" class="content-block-link gap-xsmall inline-block">
                <div class="image-ratio_3x4">
                  <img width="1216" height="832" alt="Alex Rivera" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/c4f41780-2208-4c64-8e08-5867f8158c44.avif" loading="lazy" class="image_cover position_relative">
                </div>
                <div class="content-block">
                  <div class="heading_xsmall">Alex Rivera</div>
                  <div class="author_info">Lead Economist</div>
                </div>
              </a>
            </div>
            <div class="ix-link-wrapper">
              <a href="#" class="content-block-link gap-xsmall inline-block">
                <div class="image-ratio_3x4">
                  <img width="1216" height="832" alt="Taylor Novak" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/26a740d0-a475-41fc-a4a5-6ea41ba08774.avif" loading="lazy" class="image_cover position_relative">
                </div>
                <div class="content-block">
                  <div class="heading_xsmall">Taylor Novak</div>
                  <div class="author_info">Policy Director</div>
                </div>
              </a>
            </div>
            <div class="ix-link-wrapper">
              <a href="#" class="content-block-link gap-xsmall inline-block">
                <div class="image-ratio_3x4">
                  <img width="1216" height="832" alt="Morgan Ellis" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/d169e060-a8f6-429e-852f-a2b0eea2ea18.avif" loading="lazy" class="image_cover position_relative">
                </div>
                <div class="content-block">
                  <div class="heading_xsmall">Morgan Ellis</div>
                  <div class="author_info">Communications Lead</div>
                </div>
              </a>
            </div>
            <div class="ix-link-wrapper">
              <a href="#" class="content-block-link gap-xsmall inline-block">
                <div class="image-ratio_3x4">
                  <img width="1216" height="832" alt="Jordan Kim" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/613530dd-3376-43c4-91a9-abd671c72022.avif" loading="lazy" class="image_cover position_relative">
                </div>
                <div class="content-block">
                  <div class="heading_xsmall">Jordan Kim</div>
                  <div class="author_info">Research Coordinator</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="header is-align-center">
        <div class="eyebrow">Upcoming events</div>
        <h2 class="heading_primary">Connect. Learn. Engage. Advance.</h2>
        <div class="rich-text subheading">
          <p>Join our educational events to explore modern monetary theory with leading experts and peers across Europe.</p>
        </div>
      </div>
      <div class="grid grid_3-col tablet-1-col-1-2 gap-small">
        <div class="ix-link-wrapper">
          <a href="/stockholm-event" class="card-link height_100percent inline-block">
            <div class="image-ratio_3x2 position_relative flex_horizontal is-x-right radius_bottom-none">
              <img width="1216" height="832" alt="Stockholm event" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/111bd28a-ae9e-4dc7-817e-320a08d25f45.avif" loading="lazy" class="image_cover">
              <div class="position_absolute padding_xsmall">
                <div class="card">
                  <div class="padding_xsmall text-align_center">
                    <div class="paragraph_small margin-bottom_none">Fri</div>
                    <div class="paragraph_xxlarge margin-bottom_none"><strong>27</strong></div>
                    <div class="paragraph_small margin-bottom_none">Jun 2026</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="card_body">
              <div class="tag_group margin-bottom_xsmall">
                <div class="tag"><div>Conference</div></div>
              </div>
              <h4 class="heading_tertiary">Stockholm Summer Seminar</h4>
              <div class="label">Stockholm, Sweden</div>
              <p>A one-day event featuring presentations and discussions on modern monetary theory and its relevance for European policy.</p>
              <div class="margin_top-auto padding-top_xsmall">
                <div class="text-button"><div>Details</div></div>
              </div>
            </div>
          </a>
        </div>
        <div class="ix-link-wrapper">
          <a href="/brussels-event" class="card-link height_100percent inline-block">
            <div class="image-ratio_3x2 position_relative flex_horizontal is-x-right radius_bottom-none">
              <img width="1216" height="832" alt="Brussels event" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/d35ef877-f88d-4626-888b-3da44c756954.avif" loading="lazy" class="image_cover">
              <div class="position_absolute padding_xsmall">
                <div class="card">
                  <div class="padding_xsmall text-align_center">
                    <div class="paragraph_small margin-bottom_none">Sat</div>
                    <div class="paragraph_xxlarge margin-bottom_none"><strong>28</strong></div>
                    <div class="paragraph_small margin-bottom_none">Jun 2026</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="card_body">
              <div class="tag_group margin-bottom_xsmall">
                <div class="tag"><div>Conference</div></div>
              </div>
              <h4 class="heading_tertiary">Brussels Main Conference</h4>
              <div class="label">Brussels, Belgium</div>
              <p>A two-day gathering with MMT scholars, panels, and networking for academics, professionals, and the public.</p>
              <div class="margin_top-auto padding-top_xsmall">
                <div class="text-button"><div>Details</div></div>
              </div>
            </div>
          </a>
        </div>
        <div class="ix-link-wrapper">
          <a href="/brussels-event" class="card-link height_100percent inline-block">
            <div class="image-ratio_3x2 position_relative flex_horizontal is-x-right radius_bottom-none">
              <img width="1216" height="832" alt="Workshop" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/c5741f86-ecbe-48df-9dd0-af8c93bd3f34.avif" loading="lazy" class="image_cover">
              <div class="position_absolute padding_xsmall">
                <div class="card">
                  <div class="padding_xsmall text-align_center">
                    <div class="paragraph_small margin-bottom_none">Sun</div>
                    <div class="paragraph_xxlarge margin-bottom_none"><strong>29</strong></div>
                    <div class="paragraph_small margin-bottom_none">Jun 2026</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="card_body">
              <div class="tag_group margin-bottom_xsmall">
                <div class="tag"><div>Workshop</div></div>
              </div>
              <h4 class="heading_tertiary">Policy Workshop</h4>
              <div class="label">Brussels, Belgium</div>
              <p>Interactive workshop focused on practical applications of MMT for European policymakers and advocates.</p>
              <div class="margin_top-auto padding-top_xsmall">
                <div class="text-button"><div>Details</div></div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section is-secondary">
    <div class="container">
      <div class="grid grid_2-col tablet-1-col gap-small">
        <div class="card on-secondary">
          <div class="card_body is-y-center">
            <div class="header margin-bottom_none">
              <div class="eyebrow">Stay informed</div>
              <h2 class="heading_primary">Join the MMT conversation</h2>
              <div class="rich-text subheading">
                <p>Subscribe for updates on events, research, and resources about modern monetary systems in Europe.</p>
              </div>
            </div>
            <div class="button-group">
              <div class="form_block margin_top-auto form-wrapper">
                <form method="POST" action="https://tally.so/r/Xx4q1L" id="email-form">
                  <div class="form_horizontal-wrapper">
                    <div class="form_item margin-bottom_none width_100percent">
                      <label for="email-3" class="input_label screen-reader">Your email</label>
                      <input class="input_field form-input" maxlength="256" name="email-3" placeholder="Email" type="email" id="email-3" required>
                    </div>
                    <div class="ix-link-wrapper">
                      <input type="submit" class="button btn" value="Submit">
                    </div>
                  </div>
                </form>
                <div class="form_success-message form-wrapper-done" style="display: none;">
                  <div>Thank you for subscribing.</div>
                </div>
                <div class="form_error-message form-wrapper-fail" style="display: none;">
                  <div>Submission failed. Please try again.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="image-ratio_auto">
          <img width="1216" height="832" alt="Team discussion" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/638b0e0b-607f-4d18-a5ca-b69e4f346744.avif" loading="lazy" class="image_cover">
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
