---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Brussels Event - Modern Money Lab Europe" description="Join us in Brussels on June 28-29 for a two-day conference featuring MMT scholars, panels, and networking.">
  <Nav currentPage="brussels-event" />

  <header class="section is-inverse">
    <div class="container">
      <div class="grid grid_5-col tablet-1-col-1-2-3 gap-small">
        <div class="grid-item-manual position_relative">
          <div class="header margin-bottom_none">
            <h1 class="heading_hero">MML EU Brussels Conference 2026</h1>
            <div class="subheading rich-text">
              <p>Join us in Brussels on June 28-29 for a two-day conference where top economists, scholars, and policymakers will explore Modern Monetary Theory and its implications for European policy.</p>
            </div>
            <div class="button-group">
              <div class="ix-link-wrapper">
                <a href="https://tally.so/r/q4RPog" class="button on-inverse btn">Register Now</a>
              </div>
              <div class="ix-link-wrapper">
                <a href="#agenda" class="button is-secondary on-inverse btn">Event Details</a>
              </div>
            </div>
          </div>
        </div>
        <div class="grid-item-manual mask_fade-right">
          <div class="image-ratio_1x1 position_relative">
            <img width="1216" height="832" alt="Brussels conference" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/d35ef877-f88d-4626-888b-3da44c756954.avif" loading="lazy" class="image_cover">
            <div class="overlay backdrop-filter_blur_medium mask_fade-left"></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section id="agenda" class="section">
    <div class="container">
      <div class="header is-align-center">
        <div class="eyebrow">June 28-29, 2026</div>
        <h2 class="heading_primary">Brussels conference agenda</h2>
        <div class="rich-text subheading">
          <p>Two days of presentations, panels, and workshops exploring Modern Monetary Theory and its policy implications for Europe.</p>
        </div>
      </div>
      <div class="tabs">
        <div class="tabs_nav is-align-center tab-menu">
          <a data-w-tab="Tab 1" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link current">
            <div>Day 1 Morning</div>
          </a>
          <a data-w-tab="Tab 2" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link">
            <div>Day 1 Afternoon</div>
          </a>
          <a data-w-tab="Tab 3" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link">
            <div>Day 2</div>
          </a>
        </div>
        <div class="tabs_content tab-content">
          <div data-w-tab="Tab 1" class="tab-pane tab-active">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Conference venue" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/31d2f056-0448-4565-89ac-d0655f5a7e9b.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Brussels, Belgium</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">09:00 - 10:30</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Welcome and opening keynote</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speaker</div>
                          <p>Alex Jensen</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Introduction to MML Europe and overview of the two-day programme exploring MMT in the European context.</p>
                        </div>
                      </div>
                    </div>
                    <div class="paragraph_large">10:45 - 12:00</div>
                    <div class="grid grid-2">
                      <h4 class="heading_tertiary">MMT and the Eurozone</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speaker</div>
                          <p>Taylor Schmidt</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Exploring how MMT principles apply to the eurozone framework and EU fiscal rules.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 2" class="tab-pane">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Panel discussion" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/31d2f056-0448-4565-89ac-d0655f5a7e9b.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Brussels, Belgium</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">14:00 - 15:30</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Panel: EU Fiscal Policy</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speakers</div>
                          <p>Morgan Ellis, Casey Rivera, Jordan Kim, Riley Chen</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Discussion on European fiscal coordination and policy opportunities from an MMT perspective.</p>
                        </div>
                      </div>
                    </div>
                    <div class="paragraph_large">16:00 - 17:30</div>
                    <div class="grid grid-2">
                      <h4 class="heading_tertiary">Workshop: Green New Deal for Europe</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Facilitator</div>
                          <p>Alex Rivera</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>How MMT informs approaches to climate investment and sustainable development in the EU.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 3" class="tab-pane">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Day 2 sessions" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/d1867834-9b29-4782-8fb1-8f70be2a04b2.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Brussels, Belgium</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">09:00 - 12:00</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Morning sessions and workshops</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Sessions</div>
                          <p>Multiple parallel sessions on employment, public investment, and monetary sovereignty</p>
                        </div>
                      </div>
                    </div>
                    <div class="paragraph_large">14:00 - 16:00</div>
                    <div class="grid grid-2">
                      <h4 class="heading_tertiary">Closing keynote and networking</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Host</div>
                          <p>Taylor Schmidt</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Synthesis of conference insights and next steps for MMT advocacy in Europe.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section is-secondary">
    <div class="container">
      <div class="grid grid_2-col tablet-1-col gap-small">
        <div class="card on-secondary">
          <div class="card_body is-y-center">
            <div class="header margin-bottom_none">
              <div class="eyebrow">Register now</div>
              <h2 class="heading_primary">Join us in Brussels</h2>
              <div class="rich-text subheading">
                <p>Secure your spot at the Brussels Conference. Two days of learning, discussion, and networking with MMT experts.</p>
              </div>
            </div>
            <div class="button-group">
              <div class="ix-link-wrapper">
                <a href="https://tally.so/r/q4RPog" class="button btn">Register</a>
              </div>
            </div>
          </div>
        </div>
        <div class="image-ratio_auto">
          <img width="1216" height="832" alt="Brussels" src="/images/13d8ffa5-d841-4201-910d-49215fa562d5.avif" loading="lazy" class="image_cover">
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
