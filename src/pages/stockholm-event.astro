---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Stockholm Event - Modern Money Lab Europe" description="Join us in Stockholm on June 27 for a pivotal event where top economists and policymakers will discuss the latest in economic strategies.">
  <Nav currentPage="stockholm-event" />

  <header class="section is-inverse">
    <div class="container">
      <div class="grid grid_5-col tablet-1-col-1-2-3 gap-small">
        <div class="grid-item-manual position_relative">
          <div class="header margin-bottom_none">
            <h1 class="heading_hero">MML EU Stockholm Event 2026</h1>
            <div class="subheading rich-text">
              <p>Join us in Stockholm on June 27 for a pivotal event where top economists and policymakers will discuss the latest in economic strategies. Be part of the conversation shaping Europe's financial future.</p>
            </div>
            <div class="button-group">
              <div class="ix-link-wrapper">
                <a href="https://tally.so/r/q4RPog" class="button on-inverse btn">Register Now</a>
              </div>
              <div class="ix-link-wrapper">
                <a href="#agenda" class="button is-secondary on-inverse btn">Event Details</a>
              </div>
            </div>
          </div>
        </div>
        <div class="grid-item-manual mask_fade-right">
          <div class="image-ratio_1x1 position_relative">
            <img width="1216" height="832" alt="Stockholm event" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/638b0e0b-607f-4d18-a5ca-b69e4f346744.avif" loading="lazy" class="image_cover">
            <div class="overlay backdrop-filter_blur_medium mask_fade-left"></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section id="agenda" class="section">
    <div class="container">
      <div class="header is-align-center">
        <div class="eyebrow">June 27, 2026</div>
        <h2 class="heading_primary">Stockholm event agenda</h2>
        <div class="rich-text subheading">
          <p>A full day of presentations, panels, and workshops exploring Modern Monetary Theory and its policy implications for Sweden.</p>
        </div>
      </div>
      <div class="tabs">
        <div class="tabs_nav is-align-center tab-menu">
          <a data-w-tab="Tab 1" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link current">
            <div>Morning</div>
          </a>
          <a data-w-tab="Tab 2" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link">
            <div>Afternoon</div>
          </a>
          <a data-w-tab="Tab 3" class="tab_menu-button width_100percent_mobile-l text-align_center tab-link">
            <div>Evening</div>
          </a>
        </div>
        <div class="tabs_content tab-content">
          <div data-w-tab="Tab 1" class="tab-pane tab-active">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Event venue" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/31d2f056-0448-4565-89ac-d0655f5a7e9b.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Stockholm, Sweden</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">09:00 - 10:30</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Welcome and opening remarks</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speaker</div>
                          <p>Alex Jensen</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Introduction to MML Europe and overview of the day's programme exploring MMT in the Swedish context.</p>
                        </div>
                      </div>
                    </div>
                    <div class="paragraph_large">10:45 - 12:00</div>
                    <div class="grid grid-2">
                      <h4 class="heading_tertiary">Keynote: MMT and Sweden</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speaker</div>
                          <p>Taylor Schmidt</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Exploring how MMT principles apply to currency-issuing nations and the unique position of Sweden.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 2" class="tab-pane">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Panel discussion" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/31d2f056-0448-4565-89ac-d0655f5a7e9b.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Stockholm, Sweden</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">14:00 - 15:30</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Panel: Fiscal Policy in Sweden</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Speakers</div>
                          <p>Morgan Ellis, Casey Rivera, Jordan Kim</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Discussion on Swedish fiscal policy opportunities and challenges from an MMT perspective.</p>
                        </div>
                      </div>
                    </div>
                    <div class="paragraph_large">16:00 - 17:30</div>
                    <div class="grid grid-2">
                      <h4 class="heading_tertiary">Workshop: Practical Applications</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Facilitator</div>
                          <p>Alex Rivera</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Interactive session exploring practical MMT applications for Swedish policymakers.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 3" class="tab-pane">
            <div class="flex_vertical gap-xsmall">
              <div class="card">
                <div class="grid grid_2-col tablet-1-col gap-none">
                  <div class="image-ratio_1x1 position_relative flex_horizontal is-y-top radius_none">
                    <img width="1216" height="832" alt="Networking" src="https://webflow-prod-assets.s3.amazonaws.com/image-generation-assets/d1867834-9b29-4782-8fb1-8f70be2a04b2.avif" loading="lazy" class="image_cover">
                    <div class="tag position_absolute margin-left_small margin-top_xsmall z-index_2">
                      <div class="flex_horizontal is-y-center gap-xxsmall">
                        <div class="display_inline-block">Stockholm, Sweden</div>
                      </div>
                    </div>
                  </div>
                  <div class="card_body">
                    <div class="paragraph_large">18:00 - 19:30</div>
                    <div class="grid grid">
                      <h4 class="heading_tertiary">Closing remarks and networking</h4>
                      <div class="margin_bottom-auto flex_vertical gap-xsmall">
                        <div>
                          <div class="label">Host</div>
                          <p>Taylor Schmidt</p>
                        </div>
                        <div>
                          <div class="label">Details</div>
                          <p>Wrap-up of key insights from the day, followed by networking reception with refreshments.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section is-secondary">
    <div class="container">
      <div class="grid grid_2-col tablet-1-col gap-small">
        <div class="card on-secondary">
          <div class="card_body is-y-center">
            <div class="header margin-bottom_none">
              <div class="eyebrow">Register now</div>
              <h2 class="heading_primary">Join us in Stockholm</h2>
              <div class="rich-text subheading">
                <p>Secure your spot at the Stockholm Summer Seminar. Connect with leading MMT experts and peers.</p>
              </div>
            </div>
            <div class="button-group">
              <div class="ix-link-wrapper">
                <a href="https://tally.so/r/q4RPog" class="button btn">Register</a>
              </div>
            </div>
          </div>
        </div>
        <div class="image-ratio_auto">
          <img width="1216" height="832" alt="Stockholm" src="/images/45d7c020-60db-4d5e-837d-6e1a2d5204da.avif" loading="lazy" class="image_cover">
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
